# ============================================
# Utilities
# ============================================

def load_yaml(filepath: Path) -> Dict:
    """Load YAML file"""
    if not filepath.exists():
        return {}
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            return yaml.safe_load(f) or {}
    except Exception as e:
        print(f"Error loading {filepath}: {e}")
        return {}


def save_yaml(filepath: Path, data: Dict):
    """Save YAML file"""
    filepath.parent.mkdir(parents=True, exist_ok=True)
    with open(filepath, 'w', encoding='utf-8') as f:
        yaml.dump(data, f, default_flow_style=False, allow_unicode=True, sort_keys=False)


def get_agent_info() -> Dict:
    """Get current agent/session info"""
    return {
        'agent_id': os.getenv('AGENT_ID', f'agent-{uuid4().hex[:8]}'),
        'session_id': os.getenv('SESSION_ID', f'ses-{uuid4().hex[:12]}'),
        'timestamp': datetime.now().isoformat(),
        'branch': get_git_branch()
    }


def get_git_branch() -> str:
    """Get current git branch"""
    try:
        import subprocess
        result = subprocess.run(
            ['git', 'rev-parse', '--abbrev-ref', 'HEAD'],
            capture_output=True, text=True, cwd=Path.cwd()
        )
        return result.stdout.strip() if result.returncode == 0 else 'unknown'
    except:
        return 'unknown'


def append_event(event_type: str, data: Dict) -> str:
    """Append event to events.yaml"""
    event_id = f"evt-{uuid4().hex[:12]}"
    agent_info = get_agent_info()
    
    event = {
        'id': event_id,
        'timestamp': agent_info['timestamp'],
        'agent_id': agent_info['agent_id'],
        'session_id': agent_info['session_id'],
        'type': event_type,
        'data': data
    }
    
    events_data = load_yaml(EVENTS_FILE)
    if 'events' not in events_data:
        events_data['events'] = []
        events_data['version'] = '1.0.0'
    
    events_data['events'].append(event)
    save_yaml(EVENTS_FILE, events_data)
    
    return event_id


def print_result(success: bool, message: str, data: Optional[Dict] = None):
    """Print formatted result"""
    if '--json' in sys.argv:
        result = {'success': success, 'message': message}
        if data:
            result['data'] = data
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        icon = '✅' if success else '❌'
        print(f"{icon} {message}")
        if data:
            for k, v in data.items():
                print(f"   {k}: {v}")


