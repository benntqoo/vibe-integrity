def cmd_init(args):
    """Initialize .vibe-integrity directory"""
    VIBE_DIR.mkdir(parents=True, exist_ok=True)
    
    # Create initial files
    if not EVENTS_FILE.exists():
        save_yaml(EVENTS_FILE, {
            'version': '1.0.0',
            'events': []
        })
    
    if not STATE_FILE.exists():
        save_yaml(STATE_FILE, {
            'version': '1.0.0',
            'last_folded': datetime.now().isoformat(),
            'decisions': {},
            'risks': {}
        })
    
    if not TECH_RECORDS_FILE.exists():
        save_yaml(TECH_RECORDS_FILE, {
            'version': '1.0',
            'records': []
        })
    
    if not RISK_ZONES_FILE.exists():
        save_yaml(RISK_ZONES_FILE, {
            'version': '1.0',
            'risks': []
        })
    
    if not PROJECT_FILE.exists():
        project_name = args.name if hasattr(args, 'name') and args.name else Path.cwd().name
        tech_stack = args.tech.split(',') if hasattr(args, 'tech') and args.tech else []
        save_yaml(PROJECT_FILE, {
            'name': project_name,
            'description': '',
            'tech_stack': tech_stack,
            'created_at': datetime.now().isoformat()
        })
    
    print_result(True, "Initialized .vibe-integrity/", {
        'files_created': ['events.yaml', 'state.yaml', 'tech-records.yaml', 
                         'risk-zones.yaml', 'project.yaml']
        })
    return 0


def cmd_search(args):
    """Search in records and risks"""
    query = args.query.lower()
    
    # Search in tech records
    tech_data = load_yaml(TECH_RECORDS_FILE)
    results = []
    
    for record in tech_data.get('records', []):
        text = json.dumps(record) + str(record.get('title', '')) + str(record.get('decision', '')) + str(record.get('reason', '')).lower()
        if query in text:
            results.append({
                'type': 'tech',
                'id': record.get('id'),
                'title': record.get('title'),
                'match': query
            })
    
    # Search in risks
    risk_data = load_yaml(RISK_ZONES_FILE)
    for risk in risk_data.get('risks', []):
        text = json.dumps(risk) + str(risk.get('area', '')) + str(risk.get('description', '')).lower()
        if query in text:
            results.append({
                'type': 'risk',
                'id': risk.get('id'),
                'area': risk.get('area'),
                'match': query
            })
    
    if results:
        print_result(True, f"Found {len(results)} match(es)")
        for r in results:
            print(f"   [{r['type']}] {r['id']}: {r.get('title') or r.get('area')}")
    else:
        print_result(False, "No matches found")
    
    return 0


def cmd_history(args):
    """Show event history"""
    events_data = load_yaml(EVENTS_FILE)
    events = events_data.get('events', [])
    
    if not events:
        print_result(False, "No events recorded")
        return 0
    
    # Filter by type if specified
    if hasattr(args, 'type') and args.type:
        events = [e for e in events if e.get('type') == args.type]
    
    # Limit
    limit = args.limit if hasattr(args, 'limit') else 10
    events = events[-limit:]
    
    print(f"\n📜 Event History (showing {len(events)} of {len(events_data.get('events', []))} total)")
    print("=" * 50)
    
    for event in events:
        timestamp = event.get('timestamp', '')
        if hasattr(timestamp, 'isoformat'):
            timestamp = timestamp.isoformat()
        print(f"\n[{event.get('id')}] {event.get('type')} - {str(timestamp)[:10]}")
        data = event.get('data', {})
        if 'title' in data:
            print(f"   Title: {data['title']}")
        if 'area' in data:
            print(f"   Area: {data['area']}")
        if 'description' in data:
            print(f"   Desc: {data['description'][:60]}...")
    
    return 0


