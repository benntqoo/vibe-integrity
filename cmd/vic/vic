#!/usr/bin/env python3
"""
vic - Vibe Integrity CLI
========================

简化命令行工具，用于 AI 和人类操作 .vibe-integrity/ 文件。

Usage:
    vic record tech --id DB-001 --title "Use PostgreSQL" --decision "Primary DB"
    vic record risk --id RISK-001 --area auth --desc "JWT handling"
    vic check                    # 检查代码对齐
    vic validate                 # 完整验证
    vic fold                     # 折叠事件到状态
    vic status                   # 显示当前状态

Install:
    # Linux/macOS
    chmod +x vic
    sudo ln -s $(pwd)/vic /usr/local/bin/vic
    
    # Windows (PowerShell Admin)
    # Add this directory to PATH
"""

