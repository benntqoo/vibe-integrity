def cmd_import(args):
    """Import data from a file to .vibe-integrity/"""
    input_file = args.file
    
    if not Path(input_file).exists():
        print_result(False, f"File not found: {input_file}")
        return 1
    
    # Read file
    with open(input_file, 'r', encoding='utf-8') as f:
        if input_file.endswith('.yaml') or input_file.endswith('.yml'):
            import_data = yaml.safe_load(f) or {}
        else:
            import_data = json.load(f)
    
    # Determine merge strategy
    merge = hasattr(args, 'merge') and args.merge
    
    imported_counts = {'tech_records': 0, 'risks': 0, 'events': 0}
    
    # Import tech records
    if 'tech_records' in import_data:
        existing = load_yaml(TECH_RECORDS_FILE)
        if 'records' not in existing:
            existing['records'] = []
        
        existing_ids = {r.get('id') for r in existing['records'] if r.get('id')}
        
        for record in import_data['tech_records'].get('records', []):
            if merge and record.get('id') in existing_ids:
                # Update existing
                for i, r in enumerate(existing['records']):
                    if r.get('id') == record.get('id'):
                        existing['records'][i].update(record)
                        break
            else:
                # Add new
                existing['records'].append(record)
            imported_counts['tech_records'] += 1
        
        save_yaml(TECH_RECORDS_FILE, existing)
    
    # Import risks
    if 'risks' in import_data:
        existing = load_yaml(RISK_ZONES_FILE)
        if 'risks' not in existing:
            existing['risks'] = []
        
        existing_ids = {r.get('id') for r in existing['risks'] if r.get('id')}
        
        for risk in import_data['risks'].get('risks', []):
            if merge and risk.get('id') in existing_ids:
                for i, r in enumerate(existing['risks']):
                    if r.get('id') == risk.get('id'):
                        existing['risks'][i].update(risk)
                        break
            else:
                existing['risks'].append(risk)
            imported_counts['risks'] += 1
        
        save_yaml(RISK_ZONES_FILE, existing)
    
    # Import events (always append)
    if 'events' in import_data:
        existing = load_yaml(EVENTS_FILE)
        if 'events' not in existing:
            existing['events'] = []
        
        for event in import_data['events'].get('events', []):
            existing['events'].append(event)
            imported_counts['events'] += 1
        
        save_yaml(EVENTS_FILE, existing)
    
    print_result(True, f"Imported from {input_file}", imported_counts)
    return 0


