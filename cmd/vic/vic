        existing_ids = {r.get('id') for r in existing['risks'] if r.get('id')}
        for risk in import_data['risks'].get('risks', []):
            if risk.get('id') not in existing_ids:
                existing['risks'].append(risk)
                imported_counts['risks'] += 1
        
        save_yaml(RISK_ZONES_FILE, existing)
    
    # Import events (always append)
    if 'events' in import_data:
        existing = load_yaml(EVENTS_FILE)
        if 'events' not in existing:
            existing['events'] = []
        
        for event in import_data['events'].get('events', []):
            existing['events'].append(event)
            imported_counts['events'] += 1
        
        save_yaml(EVENTS_FILE, existing)
    
    print_result(True, f"Imported from {input_file}", imported_counts)
    return 0


def create_parser():
    parser = argparse.ArgumentParser(
        prog='vic',
        description='Vibe Integrity CLI - Manage .vibe-integrity/ files'
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Commands')
    
    # record tech
    tech_parser = subparsers.add_parser('record-tech', aliases=['rt'], 
                                        help='Record a technical decision')
    tech_parser.add_argument('--id', required=True, help='Record ID (e.g., DB-001)')
    tech_parser.add_argument('--title', required=True, help='Decision title')
    tech_parser.add_argument('--decision', required=True, help='The decision')
    tech_parser.add_argument('--category', help='Category (database, auth, frontend, etc.)')
    tech_parser.add_argument('--reason', help='Why this decision was made')
    tech_parser.add_argument('--impact', choices=['low', 'medium', 'high'], help='Impact level')
    tech_parser.add_argument('--status', choices=['planned', 'in_progress', 'completed', 'deprecated'])
    tech_parser.add_argument('--files', help='Related files (comma-separated)')
    tech_parser.set_defaults(func=cmd_record_tech)
    
    # record risk
    risk_parser = subparsers.add_parser('record-risk', aliases=['rr'],
                                        help='Record a risk')
    risk_parser.add_argument('--id', required=True, help='Risk ID (e.g., RISK-001)')
    risk_parser.add_argument('--area', required=True, help='Risk area')
    risk_parser.add_argument('--desc', required=True, help='Risk description')
    risk_parser.add_argument('--category', help='Category')
    risk_parser.add_argument('--impact', choices=['low', 'medium', 'high', 'critical'])
    risk_parser.add_argument('--status', choices=['identified', 'mitigating', 'resolved', 'accepted'])
    risk_parser.set_defaults(func=cmd_record_risk)
    
    # record dependency
    dep_parser = subparsers.add_parser('record-dep', aliases=['rd'],
                                       help='Record a dependency')
    dep_parser.add_argument('--module', required=True, help='Module name')
    dep_parser.add_argument('--deps', help='Dependencies (comma-separated)')
    dep_parser.add_argument('--type', help='Dependency type (runtime, dev, etc.)')
    dep_parser.set_defaults(func=cmd_record_dep)
    
    # check
    check_parser = subparsers.add_parser('check', help='Check code alignment')
    check_parser.set_defaults(func=cmd_check)
    
    # validate
    validate_parser = subparsers.add_parser('validate', help='Run full validation')
    validate_parser.set_defaults(func=cmd_validate)
    
    # fold
    fold_parser = subparsers.add_parser('fold', help='Fold events to state')
    fold_parser.set_defaults(func=cmd_fold)
    
    # status
    status_parser = subparsers.add_parser('status', help='Show project status')
    status_parser.set_defaults(func=cmd_status)
    
    # init
    init_parser = subparsers.add_parser('init', help='Initialize .vibe-integrity/')
    init_parser.add_argument('--name', help='Project name')
    init_parser.add_argument('--tech', help='Tech stack (comma-separated)')
    init_parser.set_defaults(func=cmd_init)
    
    # search
    search_parser = subparsers.add_parser('search', help='Search in records and risks')
    search_parser.add_argument('query', help='Search query')
    search_parser.set_defaults(func=cmd_search)
    
    # history
    history_parser = subparsers.add_parser('history', help='Show event history')
    history_parser.add_argument('--type', help='Filter by event type')
    history_parser.add_argument('--limit', type=int, help='Number of events to show')
    history_parser.set_defaults(func=cmd_history)
    
    # export
    export_parser = subparsers.add_parser('export', help='Export .vibe-integrity/ data')
    export_parser.add_argument('--output', '-o', help='Output file (default: vibe-integrity-export.json)')
    export_parser.add_argument('--type', help='Filter by type (tech, risks, events)')
    export_parser.set_defaults(func=cmd_export)
    
    # import
    import_parser = subparsers.add_parser('import', help='Import data from a file')
    import_parser.add_argument('input', help='Input file to import')
    import_parser.set_defaults(func=cmd_import)
    
    return parser





def main():
    parser = create_parser()
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return 0
    
    if hasattr(args, 'func'):
        return args.func(args) or 0
    
    return 0


if __name__ == '__main__':
    sys.exit(main())
