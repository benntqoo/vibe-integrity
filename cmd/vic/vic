def cmd_record_tech(args):
    """Record a technical decision"""
    record = {
        'id': args.id,
        'date': datetime.now().strftime('%Y-%m-%d'),
        'category': args.category or 'architecture',
        'title': args.title,
        'decision': args.decision,
        'reason': args.reason or '',
        'impact': args.impact or 'medium',
        'status': args.status or 'completed'
    }
    
    if args.files:
        record['related_files'] = args.files.split(',')
    
    # Load and update tech-records.yaml
    data = load_yaml(TECH_RECORDS_FILE)
    if 'records' not in data:
        data['records'] = []
    
    # Check for duplicate ID
    existing_ids = {r.get('id') for r in data['records'] if r.get('id')}
    if record['id'] in existing_ids:
        # Update existing
        for i, r in enumerate(data['records']):
            if r.get('id') == record['id']:
                data['records'][i].update(record)
                break
    else:
        data['records'].append(record)
    
    save_yaml(TECH_RECORDS_FILE, data)
    
    # Append event
    event_id = append_event('decision_made', record)
    
    print_result(True, f"Recorded tech decision: {args.id}", {
        'title': args.title,
        'event_id': event_id
    })


def cmd_record_risk(args):
    """Record a risk"""
    risk = {
        'id': args.id,
        'date': datetime.now().strftime('%Y-%m-%d'),
        'category': args.category or 'architecture',
        'area': args.area,
        'description': args.desc,
        'impact': args.impact or 'medium',
        'status': args.status or 'identified'
    }
    
    # Load and update risk-zones.yaml
    data = load_yaml(RISK_ZONES_FILE)
    if 'risks' not in data:
        data['risks'] = []
    
    existing_ids = {r.get('id') for r in data['risks'] if r.get('id')}
    if risk['id'] in existing_ids:
        for i, r in enumerate(data['risks']):
            if r.get('id') == risk['id']:
                data['risks'][i].update(risk)
                break
    else:
        data['risks'].append(risk)
    
    save_yaml(RISK_ZONES_FILE, data)
    
    # Append event
    event_id = append_event('risk_identified', risk)
    
    print_result(True, f"Recorded risk: {args.id}", {
        'area': args.area,
        'impact': args.impact or 'medium',
        'event_id': event_id
    })


def cmd_record_dep(args):
    """Record a dependency"""
    dep = {
        'module': args.module,
        'depends_on': args.deps.split(',') if args.deps else [],
        'type': args.type or 'runtime',
        'added_at': datetime.now().isoformat()
    }
    
    data = load_yaml(VIBE_DIR / 'dependency-graph.yaml')
    if 'dependencies' not in data:
        data['dependencies'] = {}
    
    data['dependencies'][args.module] = dep
    save_yaml(VIBE_DIR / 'dependency-graph.yaml', data)
    
    event_id = append_event('dependency_added', dep)
    
    print_result(True, f"Recorded dependency: {args.module}", {
        'depends_on': args.deps,
        'event_id': event_id
    })


def cmd_check(args):
    """Check code alignment with tech records"""
    verify_script = Path(__file__).parent / 'verify-code-alignment.py'
    
    if not verify_script.exists():
        print_result(False, "verify-code-alignment.py not found")
        return 1
    
    import subprocess
    result = subprocess.run(
        [sys.executable, str(verify_script), '--json'],
        capture_output=True, text=True
    )
    
    try:
        output = json.loads(result.stdout)
        failed = output.get('failed_count', 0)
        summary = output.get('summary', {})
        
        if failed > 0:
            print_result(False, f"Found {failed} misalignment(s)", summary)
            return 1
        else:
            print_result(True, "All decisions align with code", summary)
            return 0
    except json.JSONDecodeError:
        print(result.stdout)
        return result.returncode


def cmd_validate(args):
    """Run full validation (check alignment + fold events)"""
    import subprocess
    
    issues_found = 0
    
    # Step 1: Run code alignment check
    print("\n🔍 Step 1: Code Alignment Check")
    print("-" * 40)
    verify_script = Path(__file__).parent / 'verify-code-alignment.py'
    
    if verify_script.exists():
        result = subprocess.run(
            [sys.executable, str(verify_script), '--json'],
            capture_output=True, text=True
        )
        
        try:
            output = json.loads(result.stdout)
            failed = output.get('failed_count', 0)
            summary = output.get('summary', {})
            
            if failed > 0:
                print_result(False, f"Found {failed} misalignment(s)", summary)
                issues_found += failed
            else:
                print_result(True, "Code alignment OK", summary)
        except json.JSONDecodeError:
            print(result.stdout)
            if result.returncode != 0:
                issues_found += 1
    else:
        print("⚠️  verify-code-alignment.py not found, skipping")
    
    # Step 2: Fold events
    print("\n📦 Step 2: Fold Events")
    print("-" * 40)
    fold_script = Path(__file__).parent / 'fold-events.py'
    
    if fold_script.exists():
        result = subprocess.run(
            [sys.executable, str(fold_script)],
            capture_output=True, text=True
        )
        print(result.stdout)
    else:
        print("⚠️  fold-events.py not found, skipping")
    
    # Summary
    print("\n" + "=" * 40)
    if issues_found == 0:
        print_result(True, "All validations passed!")
        return 0
    else:
        print_result(False, f"Found {issues_found} issue(s)")
        return 1


def cmd_fold(args):
    """Fold events to state"""
    fold_script = Path(__file__).parent / 'fold-events.py'
    
    if not fold_script.exists():
        print_result(False, "fold-events.py not found")
        return 1
    
    import subprocess
    result = subprocess.run(
        [sys.executable, str(fold_script)],
        capture_output=True, text=True
    )
    print(result.stdout)
    return result.returncode


