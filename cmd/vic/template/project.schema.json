# Vibe Integrity Framework - Project Metadata Schema
# =================================================
# Purpose: Store essential project information for AI quick understanding

$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "vibe-integrity-project"
title: "Vibe Integrity Project Metadata"
type: "object"
required:
  - name
  - version
  - tech_stack
  - status
  - created_at

properties:
  name:
    type: "string"
    description: "Project name"
    examples: ["my-saas-app", "ecommerce-platform"]

  version:
    type: "string"
    description: "Current project version (semver)"
    pattern: "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    examples: ["0.1.0", "1.0.0-beta"]

  status:
    type: "string"
    enum: ["planning", "mvp", "beta", "production", "maintenance", "deprecated"]
    description: "Project lifecycle status"

  description:
    type: "string"
    description: "Brief project description"

  created_at:
    type: "string"
    format: "date"
    description: "Project creation date (YYYY-MM-DD)"

  last_updated:
    type: "string"
    format: "date"
    description: "Last update date (YYYY-MM-DD)"

  tech_stack:
    type: "object"
    required:
      - frontend
      - backend
      - database
      - infrastructure
    properties:
      frontend:
        type: "array"
        items:
          type: "object"
          properties:
            name:
              type: "string"
            version:
              type: "string"
        example: [{"name": "Vue", "version": "3.4"}, {"name": "Vite", "version": "5.0"}]

      backend:
        type: "array"
        items:
          type: "object"
          properties:
            name:
              type: "string"
            version:
              type: "string"
        example: [{"name": "Express", "version": "4.18"}, {"name": "Node", "version": "20"}]

      database:
        type: "array"
        items:
          type: "object"
          properties:
            name:
              type: "string"
            version:
              type: "string"
            type:
              type: "string"
              enum: ["relational", "document", "key-value", "in-memory"]
        example: [{"name": "SQLite", "version": "3", "type": "relational"}]

      infrastructure:
        type: "array"
        items:
          type: "object"
          properties:
            name:
              type: "string"
            version:
              type: "string"
        example: [{"name": "Docker", "version": "24"}, {"name": "Nginx", "version": "1.25"}]

  language:
    type: "string"
    description: "Primary programming language"
    examples: ["TypeScript", "Python", "Go"]

  package_manager:
    type: "string"
    description: "Package manager used"
    examples: ["npm", "yarn", "pnpm", "pip", "cargo"]

  repository:
    type: "object"
    properties:
      type:
        type: "string"
        enum: ["git", "svn", "none"]
      url:
        type: "string"
        format: "uri"
      branch:
        type: "string"
        default: "main"

  environments:
    type: "object"
    additionalProperties:
      type: "object"
      properties:
        url:
          type: "string"
        database:
          type: "string"
        variables:
          type: "array"
          items:
            type: "string"

  key_features:
    type: "array"
    items:
      type: "string"
    description: "List of key features/implemented modules"
    examples: ["用户认证", "订单管理", "支付集成"]

  owner:
    type: "object"
    properties:
      name:
        type: "string"
      contact:
        type: "string"

  notes:
    type: "string"
    description: "Any additional notes for AI context"
