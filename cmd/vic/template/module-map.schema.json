# Module Map - Vibe Integrity
# =============================
# Purpose: AI understands the project structure at a glance

$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "vibe-integrity-module-map"
title: "Vibe Integrity Module Map"

type: "object"
required:
  - version
  - directories
  - modules

properties:
  version:
    type: "string"

  directories:
    type: "object"
    description: "Directory structure overview"
    additionalProperties:
      type: "object"
      properties:
        purpose:
          type: "string"
        contains:
          type: "array"
          items:
            type: "string"
        important_notes:
          type: "string"

  modules:
    type: "array"
    items:
      type: "object"
      required:
        - name
        - type
        - path
      properties:
        name:
          type: "string"
        type:
          type: "string"
          enum: ["service", "repository", "controller", "middleware", "component", "util", "config", "model"]
        path:
          type: "string"
        description:
          type: "string"
        exports:
          type: "array"
          items:
            type: "string"
        key_files:
          type: "array"
          items:
            type: "string"

  entry_points:
    type: "array"
    items:
      type: "object"
      properties:
        type:
          type: "string"
        path:
          type: "string"
        description:
          type: "string"

  generated_at:
    type: "string"
    format: "date-time"
