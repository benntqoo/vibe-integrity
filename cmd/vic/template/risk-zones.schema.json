# Risk Zones - Vibe Integrity
# ============================
# Purpose: AI knows which areas are high-risk before making changes
# This prevents breaking critical functionality

$schema: "https://json-schema.org/draft/2020-12/schema"
$id: "vibe-integrity-risk-zones"
title: "Vibe Integrity Risk Zones"

type: "object"
required:
  - version
  - zones
  - generated_at
  - metadata
required:
  - version
  - zones
  - generated_at

properties:
  version:
    type: "string"

  zones:
    type: "object"
    description: "Risk zone definitions"
    additionalProperties:
      type: "object"
      required:
        - risk_level
        - reason
      properties:
        risk_level:
          type: "string"
          enum: ["critical", "high", "medium", "low", "stable"]
        reason:
          type: "string"
        impact_description:
          type: "string"
        stability:
          type: "string"
          enum: ["stable", "medium", "unstable", "deprecated"]
        last_modified:
          type: "string"
          format: "date"
        related_migrations:
          type: "array"
          items:
            type: "string"
        test_coverage:
          type: "string"
          enum: ["full", "partial", "minimal", "none"]
        caution_notes:
          type: "array"
          items:
            type: "string"
        emergency_contacts:
          type: "array"
          items:
            type: "string"

  global_rules:
    type: "object"
    properties:
      high_risk_patterns:
        type: "array"
        items:
          type: "string"
      avoid_patterns:
        type: "array"
        items:
          type: "string"

  generated_at:
    type: "string"
    format: "date-time"

  metadata:
    type: "object"
    required:
      - agent_id
      - session_id
      - timestamp
      - branch
    properties:
      agent_id:
        type: "string"
      session_id:
        type: "string"
      timestamp:
        type: "string"
        format: "date-time"
      branch:
        type: "string"
