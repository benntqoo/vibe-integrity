{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sdd-machine-schema",
  "title": "Strict SDD Machine Schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "enums": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Ideation",
              "SpecDraft",
              "SpecValidated",
              "CodeGenerated",
              "Implemented",
              "ContractVerified",
              "Released"
            ]
          }
        },
        "result": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "blocked"
            ]
          }
        },
        "compatibility_mode": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "backward",
              "forward",
              "strict"
            ]
          }
        }
      },
      "required": [
        "state",
        "result",
        "compatibility_mode"
      ]
    },
    "schemas": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state_record": {
          "$ref": "#/$defs/stateRecord"
        },
        "spec_report": {
          "$ref": "#/$defs/baseReport"
        },
        "codegen_report": {
          "$ref": "#/$defs/codegenReport"
        },
        "contract_diff_report": {
          "$ref": "#/$defs/contractDiffReport"
        },
        "test_report": {
          "$ref": "#/$defs/testReport"
        },
        "traceability_report": {
          "$ref": "#/$defs/traceabilityReport"
        },
        "release_guard_report": {
          "$ref": "#/$defs/releaseGuardReport"
        }
      },
      "required": [
        "state_record",
        "spec_report",
        "codegen_report",
        "contract_diff_report",
        "test_report",
        "traceability_report",
        "release_guard_report"
      ]
    }
  },
  "required": [
    "enums",
    "schemas"
  ],
  "$defs": {
    "state": {
      "type": "string",
      "enum": [
        "Ideation",
        "SpecDraft",
        "SpecValidated",
        "CodeGenerated",
        "Implemented",
        "ContractVerified",
        "Released"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked"
      ]
    },
    "baseReport": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "feature": {
          "type": "string",
          "minLength": 1
        },
        "state_before": {
          "$ref": "#/$defs/state"
        },
        "state_after": {
          "$ref": "#/$defs/state"
        },
        "skill": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "$ref": "#/$defs/result"
        },
        "blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "feature",
        "state_before",
        "state_after",
        "skill",
        "timestamp",
        "result",
        "blocking_reasons"
      ]
    },
    "stateRecord": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "feature": {
          "type": "string",
          "minLength": 1
        },
        "current_state": {
          "$ref": "#/$defs/state"
        },
        "last_gate": {
          "type": "string",
          "minLength": 1
        },
        "last_skill": {
          "type": "string",
          "minLength": 1
        },
        "updated_at": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "$ref": "#/$defs/result"
        },
        "blocked_reason": {
          "type": "string"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "feature",
        "current_state",
        "last_gate",
        "last_skill",
        "updated_at",
        "result",
        "blocked_reason",
        "artifacts"
      ]
    },
    "codegenReport": {
      "allOf": [
        {
          "$ref": "#/$defs/baseReport"
        },
        {
          "type": "object",
          "properties": {
            "generated_files": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "changed_public_signatures": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "compatibility_result": {
              "$ref": "#/$defs/result"
            },
            "unresolved_contract_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "generated_files",
            "changed_public_signatures",
            "compatibility_result",
            "unresolved_contract_items"
          ]
        }
      ]
    },
    "contractDiffReport": {
      "allOf": [
        {
          "$ref": "#/$defs/baseReport"
        },
        {
          "type": "object",
          "properties": {
            "added_operations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "removed_operations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "signature_mismatches": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "error_contract_mismatches": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "compatibility_result": {
              "$ref": "#/$defs/result"
            },
            "requires_spec_update": {
              "type": "boolean"
            }
          },
          "required": [
            "added_operations",
            "removed_operations",
            "signature_mismatches",
            "error_contract_mismatches",
            "compatibility_result",
            "requires_spec_update"
          ]
        }
      ]
    },
    "testReport": {
      "allOf": [
        {
          "$ref": "#/$defs/baseReport"
        },
        {
          "type": "object",
          "properties": {
            "coverage_summary": {
              "type": "object"
            },
            "failed_ids": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "coverage_summary",
            "failed_ids"
          ]
        }
      ]
    },
    "traceabilityReport": {
      "allOf": [
        {
          "$ref": "#/$defs/baseReport"
        },
        {
          "type": "object",
          "properties": {
            "completeness": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "orphan_items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "completeness",
            "orphan_items"
          ]
        }
      ]
    },
    "releaseGuardReport": {
      "allOf": [
        {
          "$ref": "#/$defs/baseReport"
        },
        {
          "type": "object",
          "properties": {
            "gate_results": {
              "type": "object"
            },
            "feature_flag_plan": {
              "type": "object"
            },
            "observability_checks": {
              "type": "object"
            },
            "rollback_plan": {
              "type": "object"
            },
            "release_decision": {
              "$ref": "#/$defs/result"
            }
          },
          "required": [
            "gate_results",
            "feature_flag_plan",
            "observability_checks",
            "rollback_plan",
            "release_decision"
          ]
        }
      ]
    }
  }
}
