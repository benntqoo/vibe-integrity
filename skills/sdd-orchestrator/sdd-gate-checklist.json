{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "state_flow": [
    "Ideation",
    "SpecDraft",
    "SpecValidated",
    "CodeGenerated",
    "Implemented",
    "ContractVerified",
    "Released"
  ],
  "skills": {
    "spec-architect": {
      "entry_state": [
        "Ideation",
        "SpecDraft"
      ],
      "success_state": "SpecValidated",
      "failure_state": "SpecDraft",
      "required_outputs": [
        "docs/specs/<feature>.md",
        "docs/specs/<feature>.contract.json",
        "docs/specs/<feature>.traceability.yaml",
        "docs/specs/<feature>.risk.yaml",
        "docs/specs/<feature>.spec.report.json"
      ],
      "gate_checks": [
        "story_to_acceptance_complete",
        "acceptance_to_contract_complete",
        "contract_error_scenarios_complete",
        "compatibility_commitment_explicit",
        "no_tbd_or_todo"
      ]
    },
    "spec-to-codebase": {
      "entry_state": [
        "SpecValidated"
      ],
      "success_state": "CodeGenerated",
      "failure_state": "SpecValidated",
      "required_outputs": [
        "docs/specs/<feature>.codegen.report.json"
      ],
      "gate_checks": [
        "all_contract_operations_mapped",
        "required_input_output_fields_present",
        "no_unresolved_contract_items",
        "compatibility_result_pass"
      ]
    },
    "spec-contract-diff": {
      "entry_state": [
        "CodeGenerated",
        "Implemented"
      ],
      "success_state": "Implemented",
      "failure_state": "Implemented",
      "required_outputs": [
        "docs/specs/<feature>.contract.diff.json"
      ],
      "gate_checks": [
        "no_undeclared_removed_operation",
        "no_removed_required_output_field",
        "error_code_compatibility_pass",
        "compatibility_result_pass"
      ]
    },
    "spec-driven-test": {
      "entry_state": [
        "CodeGenerated",
        "Implemented"
      ],
      "success_state": "ContractVerified",
      "failure_state": "Implemented",
      "required_outputs": [
        "tests/specs/<feature>.contract.spec.*",
        "tests/specs/<feature>.acceptance.spec.*",
        "docs/specs/<feature>.test.report.json"
      ],
      "gate_checks": [
        "traceability_coverage_100",
        "contract_operation_coverage_100",
        "error_code_coverage_100",
        "no_flaky_markers",
        "test_report_pass"
      ]
    },
    "spec-traceability": {
      "entry_state": [
        "SpecValidated",
        "CodeGenerated",
        "Implemented",
        "ContractVerified"
      ],
      "success_state": "Implemented",
      "failure_state": "Implemented",
      "required_outputs": [
        "docs/specs/<feature>.traceability.yaml",
        "docs/specs/<feature>.traceability.report.json"
      ],
      "gate_checks": [
        "no_orphan_story",
        "no_orphan_acceptance",
        "no_orphan_contract_operation",
        "no_orphan_code_entry_point",
        "mapping_completeness_100"
      ]
    },
    "sdd-release-guard": {
      "entry_state": [
        "ContractVerified"
      ],
      "success_state": "Released",
      "failure_state": "ContractVerified",
      "required_outputs": [
        "docs/specs/<feature>.release.guard.json"
      ],
      "gate_checks": [
        "contract_diff_pass",
        "test_report_pass",
        "traceability_pass",
        "feature_flag_plan_present",
        "observability_checks_present",
        "rollback_plan_present"
      ]
    }
  }
}
