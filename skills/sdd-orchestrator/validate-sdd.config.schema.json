{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "sdd-validate-config",
  "type": "object",
  "properties": {
    "root_path": {
      "type": "string",
      "description": "Root path of the project"
    },
    "skills_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Paths to search for skills"
    },
    "orchestrator_path": {
      "type": "string",
      "description": "Path to sdd-orchestrator skill"
    },
    "schema_path": {
      "type": "string",
      "description": "Path to sdd-machine-schema.json"
    },
    "checklist_path": {
      "type": "string",
      "description": "Path to sdd-gate-checklist.json"
    },
    "recursive_search": {
      "type": "boolean",
      "default": false,
      "description": "Enable recursive search for skills"
    },
    "fast_path": {
      "type": "boolean",
      "default": false,
      "description": "Enable fast path mode for simple requirements"
    },
    "fast_path_skips": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "spec-traceability",
          "spec-contract-diff",
          "risk-assessment",
          "rollback-plan"
        ]
      },
      "default": [],
      "description": "Gates to skip in fast path mode"
    },
    "fast_path_triggers": {
      "type": "object",
      "properties": {
        "max_file_changes": {
          "type": "integer",
          "default": 5,
          "description": "Maximum file changes to qualify for fast path"
        },
        "max_complexity": {
          "type": "integer",
          "default": 3,
          "description": "Maximum complexity score (1-10) to qualify for fast path"
        },
        "allowed_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "config",
              "docs",
              "fix",
              "refactor",
              "chore"
            ]
          },
          "default": ["config", "docs", "fix"],
          "description": "Feature types allowed in fast path"
        }
      },
      "description": "Conditions that trigger fast path mode"
    },
    "strict_mode": {
      "type": "boolean",
      "default": true,
      "description": "Enable strict validation of all gates"
    }
  }
}
