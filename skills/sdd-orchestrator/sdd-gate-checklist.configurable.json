{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "1.0.0",
  "state_flow": [
    "Ideation",
    "SpecDraft",
    "SpecValidated",
    "CodeGenerated",
    "Implemented",
    "ContractVerified",
    "Released"
  ],
  "skills": {
    "spec-architect": {
      "entry_state": [
        "Ideation",
        "SpecDraft"
      ],
      "success_state": "SpecValidated",
      "failure_state": "SpecDraft",
      "required_outputs": [
        ".sdd-spec/specs/<feature>.md",
        ".sdd-spec/specs/<feature>.contract.json",
        ".sdd-spec/specs/<feature>.traceability.yaml",
        ".sdd-spec/specs/<feature>.risk.yaml",
        ".sdd-spec/specs/<feature>.spec.report.json"
      ],
      "gate_checks": [
        "story_to_acceptance_complete",
        "acceptance_to_contract_complete",
        "contract_error_scenarios_complete",
        "compatibility_commitment_explicit",
        "no_tbd_or_todo"
      ],
      "configurable_gates": {
        "risk_assessment": {
          "required": false,
          "description": "Risk assessment document"
        }
      }
    },
    "spec-to-codebase": {
      "entry_state": [
        "SpecValidated"
      ],
      "success_state": "CodeGenerated",
      "failure_state": "SpecValidated",
      "required_outputs": [
        ".sdd-spec/specs/<feature>.codegen.report.json"
      ],
      "gate_checks": [
        "all_contract_operations_mapped",
        "required_input_output_fields_present",
        "no_unresolved_contract_items",
        "compatibility_result_pass"
      ],
      "configurable_gates": {}
    },
    "spec-contract-diff": {
      "entry_state": [
        "CodeGenerated",
        "Implemented"
      ],
      "success_state": "Implemented",
      "failure_state": "Implemented",
      "required_outputs": [
        ".sdd-spec/specs/<feature>.contract.diff.json"
      ],
      "gate_checks": [
        "no_undeclared_removed_operation",
        "no_removed_required_output_field",
        "error_code_compatibility_pass",
        "compatibility_result_pass"
      ],
      "configurable_gates": {
        "strict_error_matching": {
          "required": false,
          "description": "Require exact error code matching"
        }
      }
    },
    "spec-driven-test": {
      "entry_state": [
        "CodeGenerated",
        "Implemented"
      ],
      "success_state": "ContractVerified",
      "failure_state": "Implemented",
      "required_outputs": [
        ".sdd-spec/tests/specs/<feature>.contract.spec.*",
        ".sdd-spec/tests/specs/<feature>.acceptance.spec.*",
        ".sdd-spec/specs/<feature>.test.report.json"
      ],
      "gate_checks": [
        "traceability_coverage_100",
        "contract_operation_coverage_100",
        "error_code_coverage_100",
        "no_flaky_markers",
        "test_report_pass"
      ],
      "configurable_gates": {
        "coverage_threshold": {
          "required": true,
          "default": 100,
          "description": "Minimum coverage percentage"
        }
      }
    },
    "spec-traceability": {
      "entry_state": [
        "SpecValidated",
        "CodeGenerated",
        "Implemented",
        "ContractVerified"
      ],
      "success_state": "Implemented",
      "failure_state": "Implemented",
      "required_outputs": [
        ".sdd-spec/specs/<feature>.traceability.yaml",
        ".sdd-spec/specs/<feature>.traceability.report.json"
      ],
      "gate_checks": [
        "no_orphan_story",
        "no_orphan_acceptance",
        "no_orphan_contract_operation",
        "no_orphan_code_entry_point",
        "mapping_completeness_100"
      ],
      "configurable_gates": {
        "allow_draft_status": {
          "required": false,
          "description": "Allow draft status in traceability"
        }
      }
    },
    "sdd-release-guard": {
      "entry_state": [
        "ContractVerified"
      ],
      "success_state": "Released",
      "failure_state": "ContractVerified",
      "required_outputs": [
        ".sdd-spec/specs/<feature>.release.guard.json"
      ],
      "gate_checks": [
        "contract_diff_pass",
        "test_report_pass",
        "traceability_pass",
        "feature_flag_plan_present",
        "observability_checks_present",
        "rollback_plan_present"
      ],
      "configurable_gates": {
        "feature_flag_required": {
          "required": false,
          "description": "Require feature flag for release"
        },
        "rollback_mandatory": {
          "required": true,
          "description": "Rollback plan is mandatory"
        },
        "observability_required": {
          "required": true,
          "description": "Observability checks are mandatory"
        }
      }
    }
  },
  "global_config": {
    "enforce_100_coverage": {
      "value": true,
      "description": "Enforce 100% coverage requirements"
    },
    "allow_fast_path": {
      "value": true,
      "description": "Allow fast path for simple changes"
    },
    "strict_schema_validation": {
      "value": true,
      "description": "Strict JSON schema validation"
    }
  }
}