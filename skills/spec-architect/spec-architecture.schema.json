{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spec-architecture",
  "title": "SPEC-ARCHITECTURE Schema",
  "description": "JSON Schema for validating SPEC-ARCHITECTURE.md documents. Supports both YAML and JSON formats.",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": true,
  "required": ["metadata", "tech_stack", "modules"],
  "properties": {
    "metadata": {
      "$id": "#/properties/metadata",
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "status", "owner", "created"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "spec", "frozen", "archived"]
        },
        "owner": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date"
        },
        "updated": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "tech_stack": {
      "$id": "#/properties/tech_stack",
      "type": "object",
      "required": ["overview"],
      "properties": {
        "overview": {
          "type": "object",
          "required": ["stack", "rationale"],
          "properties": {
            "final_choice": { "type": "string" },
            "rationale": { "type": "string" }
          }
        },
        "layers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["layer", "technology", "version", "status"],
            "properties": {
              "layer": { "type": "string" },
              "technology": { "type": "string" },
              "version": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["selected", "evaluating", "rejected"]
              },
              "rationale": { "type": "string" }
            }
          }
        },
        "dev_tools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tool", "purpose", "choice"],
            "properties": {
              "tool": { "type": "string" },
              "purpose": { "type": "string" },
              "choice": { "type": "string" }
            }
          }
        }
      }
    },
    "architecture": {
      "$id": "#/properties/architecture",
      "type": "object",
      "properties": {
        "diagram": {
          "type": "string",
          "description": "ASCII or Mermaid architecture diagram"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "modules": {
      "$id": "#/properties/modules",
      "type": "array",
      "minItems": 1,
      "items": {
        "$id": "#/properties/modules/items",
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "responsibility", "boundaries"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Module name"
          },
          "responsibility": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "boundaries": {
            "type": "string",
            "description": "Module boundary definition"
          },
          "public_api": {
            "type": "array",
            "items": { "type": "string" }
          },
          "responsibilities": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "directory_structure": {
      "$id": "#/properties/directory_structure",
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "tree": {
          "type": "string",
          "description": "ASCII directory tree"
        }
      }
    },
    "commands": {
      "$id": "#/properties/commands",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "functionality", "status"],
        "properties": {
          "command": {
            "type": "string",
            "description": "CLI command, e.g. 'vic init'"
          },
          "functionality": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "deferred"]
          },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "required": { "type": "boolean" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "core_modules": {
      "$id": "#/properties/core_modules",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "files"],
        "properties": {
          "name": { "type": "string" },
          "functionality": { "type": "string" },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "data_models": {
      "$id": "#/properties/data_models",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entity", "fields"],
        "properties": {
          "entity": { "type": "string" },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "description": { "type": "string" },
                "required": { "type": "boolean" }
              }
            }
          },
          "relationships": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "api_contracts": {
      "$id": "#/properties/api_contracts",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["endpoint", "method", "purpose"],
        "properties": {
          "endpoint": { "type": "string" },
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "DELETE", "PATCH", "WS", "gRPC"]
          },
          "purpose": { "type": "string" },
          "request_schema": { "type": "string" },
          "response_schema": { "type": "string" },
          "error_codes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "security": {
      "$id": "#/properties/security",
      "type": "object",
      "properties": {
        "authentication": { "type": "array", "items": { "type": "string" } },
        "authorization": { "type": "array", "items": { "type": "string" } },
        "encryption": { "type": "array", "items": { "type": "string" } },
        "protections": { "type": "array", "items": { "type": "string" } }
      }
    },
    "environment_variables": {
      "$id": "#/properties/environment_variables",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["variable", "default", "description"],
        "properties": {
          "variable": { "type": "string" },
          "default": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "deployment": {
      "$id": "#/properties/deployment",
      "type": "object",
      "properties": {
        "build": {
          "type": "array",
          "items": { "type": "string" }
        },
        "release": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "platform": { "type": "string" },
              "format": { "type": "string" }
            }
          }
        }
      }
    },
    "risk_zones": {
      "$id": "#/properties/risk_zones",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["area", "description", "mitigation"],
        "properties": {
          "area": { "type": "string" },
          "description": { "type": "string" },
          "mitigation": { "type": "string" }
        }
      }
    },
    "change_history": {
      "$id": "#/properties/change_history",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "changes", "author", "reason"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "changes": { "type": "string" },
          "author": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
