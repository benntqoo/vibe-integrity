{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spec-requirements",
  "title": "SPEC-REQUIREMENTS Schema",
  "description": "JSON Schema for validating SPEC-REQUIREMENTS.md documents. Supports both YAML and JSON formats.",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": true,
  "required": ["metadata", "stories", "acceptance_criteria"],
  "properties": {
    "metadata": {
      "$id": "#/properties/metadata",
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "status", "owner", "phase", "created"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of this spec"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "spec", "frozen", "archived"],
          "description": "Document lifecycle status"
        },
        "owner": {
          "type": "string",
          "description": "Owner identifier, e.g. @agent-name"
        },
        "phase": {
          "type": "string",
          "description": "Current phase, e.g. 'Phase 0 - 需求凝固'"
        },
        "created": {
          "type": "string",
          "format": "date",
          "description": "Creation date YYYY-MM-DD"
        },
        "updated": {
          "type": "string",
          "format": "date",
          "description": "Last update date YYYY-MM-DD"
        }
      }
    },
    "goals_and_vision": {
      "$id": "#/properties/goals_and_vision",
      "type": "object",
      "properties": {
        "objectives": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Core objectives the project aims to solve"
        },
        "target_users": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Who will use this system"
        },
        "success_metrics": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Measurable success indicators"
        }
      }
    },
    "stories": {
      "$id": "#/properties/stories",
      "type": "array",
      "minItems": 1,
      "items": {
        "$id": "#/properties/stories/items",
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "priority", "phase"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^US-\\d{3}$",
            "description": "User story ID, e.g. US-001"
          },
          "role": {
            "type": "string",
            "description": "User role, e.g. 'AI开发者'"
          },
          "goal": {
            "type": "string",
            "description": "What the user wants to achieve"
          },
          "benefit": {
            "type": "string",
            "description": "Why this matters (value)"
          },
          "description": {
            "type": "string",
            "description": "Full story description (template: 作为 [角色]，我想要 [功能]，以便 [价值])"
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"],
            "description": "Priority: P0=Critical, P1=High, P2=Medium, P3=Low"
          },
          "phase": {
            "type": "string",
            "pattern": "^Phase \\d",
            "description": "Delivery phase, e.g. 'Phase 1'"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "deferred"],
            "default": "pending"
          }
        }
      }
    },
    "functional_requirements": {
      "$id": "#/properties/functional_requirements",
      "type": "array",
      "items": {
        "$id": "#/properties/functional_requirements/items",
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "story_id", "phase", "status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F-\\d{3}$",
            "description": "Functional requirement ID, e.g. F-001"
          },
          "name": {
            "type": "string",
            "description": "Requirement name"
          },
          "story_id": {
            "type": "string",
            "pattern": "^US-\\d{3}$",
            "description": "Linked user story ID"
          },
          "phase": {
            "type": "string",
            "pattern": "^Phase \\d"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "deferred"]
          },
          "description": {
            "type": "string",
            "description": "Detailed description"
          },
          "business_rules": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Business rules governing this requirement"
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "IDs of prerequisite requirements"
          }
        }
      }
    },
    "acceptance_criteria": {
      "$id": "#/properties/acceptance_criteria",
      "type": "array",
      "minItems": 1,
      "items": {
        "$id": "#/properties/acceptance_criteria/items",
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "requirement_id", "condition", "test_method"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-\\d{3}$"
          },
          "requirement_id": {
            "type": "string",
            "pattern": "^F-\\d{3}$",
            "description": "Linked requirement ID"
          },
          "condition": {
            "type": "string",
            "description": "Concrete acceptance condition"
          },
          "test_method": {
            "type": "string",
            "enum": ["automated", "manual", "inspection"],
            "description": "How this criterion is verified"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "pass", "fail"],
            "default": "pending"
          },
          "evidence": {
            "type": "string",
            "description": "Evidence of passing (e.g. test output, screenshot)"
          }
        }
      }
    },
    "edge_cases": {
      "$id": "#/properties/edge_cases",
      "type": "array",
      "items": {
        "$id": "#/properties/edge_cases/items",
        "type": "object",
        "required": ["id", "scenario", "expected_behavior"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^BC-\\d{3}$"
          },
          "scenario": {
            "type": "string",
            "description": "Edge case scenario description"
          },
          "expected_behavior": {
            "type": "string",
            "description": "Expected system behavior"
          }
        }
      }
    },
    "phases": {
      "$id": "#/properties/phases",
      "type": "array",
      "items": {
        "$id": "#/properties/phases/items",
        "type": "object",
        "required": ["name", "goal", "scope", "done_criteria", "features"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^Phase \\d"
          },
          "goal": {
            "type": "string"
          },
          "scope": {
            "type": "object",
            "properties": {
              "includes": { "type": "array", "items": { "type": "string" } },
              "excludes": { "type": "array", "items": { "type": "string" } }
            }
          },
          "done_criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "features": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "feature_id": { "type": "string", "pattern": "^F-\\d{3}$" },
                "acceptance_criteria": {
                  "type": "array",
                  "items": { "type": "string", "pattern": "^AC-\\d{3}$" }
                },
                "owner": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "non_functional_requirements": {
      "$id": "#/properties/non_functional_requirements",
      "type": "object",
      "properties": {
        "performance": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metric", "target"],
            "properties": {
              "metric": { "type": "string" },
              "target": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "security": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["item", "requirement"],
            "properties": {
              "item": { "type": "string" },
              "requirement": { "type": "string" }
            }
          }
        },
        "reliability": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metric", "target"],
            "properties": {
              "metric": { "type": "string" },
              "target": { "type": "string" }
            }
          }
        }
      }
    },
    "dependencies": {
      "$id": "#/properties/dependencies",
      "type": "object",
      "properties": {
        "internal": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["module", "interface"],
            "properties": {
              "module": { "type": "string" },
              "description": { "type": "string" },
              "interface": { "type": "string" }
            }
          }
        },
        "external": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["service", "purpose"],
            "properties": {
              "service": { "type": "string" },
              "purpose": { "type": "string" },
              "access_method": { "type": "string" }
            }
          }
        }
      }
    },
    "glossary": {
      "$id": "#/properties/glossary",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "definition"],
        "properties": {
          "term": { "type": "string" },
          "definition": { "type": "string" }
        }
      }
    },
    "change_history": {
      "$id": "#/properties/change_history",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "changes", "author", "reason"],
        "properties": {
          "date": { "type": "string", "format": "date" },
          "changes": { "type": "string" },
          "author": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
